# Copy to .env.local and fill in for local dev
# For production (Vercel), set these in Vercel project settings

# Local dev — backend on localhost
VITE_API_URL=http://localhost:8000
VITE_API_KEY=finsight-dev-key

# Production — Railway URL (fill in after deploy)
# VITE_API_URL=https://<your-railway-app>.railway.app
# VITE_API_KEY=<same value as API_KEY in Railway env vars>
