FRED_API_KEY=your_fred_api_key_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── FinSight AI — Phoenix observability ─────────────────────────────────────
# Run Phoenix locally: docker compose up phoenix
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=finsight-ai
PHOENIX_MCP_BASE_URL=http://localhost:6006   # Python agent uses this to query Phoenix REST API
# PHOENIX_API_KEY=          # leave empty for local; set for Arize cloud

# ── FinSight AI — LLM provider ──────────────────────────────────────────────
# Set to "groq" for development, "gemini" for hackathon submission
LLM_PROVIDER=groq

# Groq (dev): get key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Gemini (submission): get key at aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Override default models (optional)
# llama-3.3-70b-versatile is recommended for both roles on Groq free tier —
# it sits in a higher TPM bucket than 8b-instant, avoiding rate-limit errors
# on report generation when the prompt contains several drift runs.
LLM_REASONING_MODEL=llama-3.3-70b-versatile
LLM_FAST_MODEL=llama-3.3-70b-versatile

# ── FinSight AI — Agent framework ──────────────────────────────────────────
# "native" uses Groq/Gemini directly. "adk" uses Google ADK 2.0 multi-agent.
AGENT_FRAMEWORK=native
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here